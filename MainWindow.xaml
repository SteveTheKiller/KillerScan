<Window x:Class="KillerScan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KillerScan"
        mc:Ignorable="d"
        Title="KillerScan"
        Height="700" Width="1100"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        BorderThickness="0"
        BorderBrush="Transparent"
        Icon="Resources/ks-icon.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="ks" Foreground="{StaticResource PrimaryBrush}"
                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="KillerScan" Foreground="{StaticResource TextBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="Network Scanner" Foreground="{StaticResource MutedTextBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="8,1,0,0"/>
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                    <Button x:Name="MinimizeBtn" Content="&#x2015;" Click="MinimizeBtn_Click"
                            Width="40" FontSize="9" VerticalAlignment="Stretch"
                            Foreground="{StaticResource MutedTextBrush}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{StaticResource TableHeaderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaximizeBtn" Content="&#x25A1;" Click="MaximizeBtn_Click"
                            Width="40" FontSize="11" VerticalAlignment="Stretch"
                            Foreground="{StaticResource MutedTextBrush}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{StaticResource TableHeaderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="CloseBtn" Content="&#x2715;" Click="CloseBtn_Click"
                            Width="40" FontSize="11" VerticalAlignment="Stretch"
                            Foreground="{StaticResource MutedTextBrush}" Background="Transparent"
                            BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scan Configuration -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="16,8,16,0">
            <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Subnet"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>

                    <TextBox Grid.Column="1" x:Name="SubnetInput"
                             Style="{StaticResource DarkTextBox}"
                             Text="192.168.1.0/24"
                             VerticalAlignment="Center"/>

                    <Button Grid.Column="2" x:Name="ScanBtn" Content="Scan"
                            Style="{StaticResource PrimaryButton}"
                            Click="ScanBtn_Click" Padding="16,6" Margin="16,0,0,0"/>

                    <!-- Network info - hacker terminal style -->
                    <Border Grid.Column="3" Background="#0a0a0a" CornerRadius="3"
                            BorderBrush="#1a1a1a" BorderThickness="1"
                            Padding="10,2" Margin="16,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="$" Foreground="#0C7A43" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold" Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="LocalIpLabel" Text="local:--"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text=" | " Foreground="#0C7A43" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="GatewayLabel" Text="gw:--"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text=" | " Foreground="#0C7A43" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="DnsLabel" Text="dns:--"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text=" | " Foreground="#0C7A43" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock x:Name="InterfaceLabel" Text="--"
                                       Foreground="{StaticResource PrimaryBrush}" FontFamily="Consolas"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Column="5" x:Name="ExportButton"
                            Style="{StaticResource SurfaceButton}"
                            Content="Export &#x25BE;" Margin="8,0,0,0"
                            IsEnabled="False"
                            Click="ExportButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Export as CSV" Click="ExportCsv_Click"/>
                                <MenuItem Header="Export as HTML" Click="ExportHtml_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
            </Grid>
        </Border>

        <!-- Results Area -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="16,6,16,6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Discovered Devices"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" x:Name="FilterInput"
                             Style="{StaticResource DarkTextBox}"
                             Width="180" Margin="16,0,0,0"
                             FontSize="12" Padding="6,4"
                             VerticalAlignment="Center"
                             TextChanged="FilterInput_TextChanged">
                        <TextBox.Tag>Filter...</TextBox.Tag>
                    </TextBox>
                    <TextBlock Grid.Column="3" x:Name="DeviceCount"
                               Text="0 devices found"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12" VerticalAlignment="Center"/>
                </Grid>

                <!-- Results DataGrid -->
                <DataGrid Grid.Row="1" x:Name="ResultsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="Transparent"
                          Foreground="{StaticResource TextBrush}"
                          BorderThickness="0"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{StaticResource CardBorderBrush}"
                          HeadersVisibility="Column"
                          CanUserSortColumns="True"
                          SelectionMode="Single"
                          ColumnHeaderHeight="36"
                          RowHeight="28"
                          AlternationCount="2"
                          RowStyle="{StaticResource DarkDataGridRow}"
                          CellStyle="{StaticResource DarkDataGridCell}">

                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy IP Address" Click="CopyIp_Click"/>
                            <MenuItem Header="Copy MAC Address" Click="CopyMac_Click"/>
                            <MenuItem Header="Copy Hostname" Click="CopyHostname_Click"/>
                            <Separator Style="{x:Null}" Background="#3a3a3a" Height="1" Margin="8,4"/>
                            <MenuItem Header="Ping" Click="PingDevice_Click"/>
                            <MenuItem Header="Open in Browser" Click="OpenBrowser_Click"/>
                            <MenuItem Header="RDP" Click="RdpDevice_Click"/>
                            <MenuItem Header="SSH" Click="SshDevice_Click"/>
                            <Separator Style="{x:Null}" Background="#3a3a3a" Height="1" Margin="8,4"/>
                            <MenuItem Header="Set Device Type">
                                <MenuItem Header="Router" Click="SetType_Click" Tag="Router"/>
                                <MenuItem Header="Switch/AP" Click="SetType_Click" Tag="Switch/AP"/>
                                <MenuItem Header="Network" Click="SetType_Click" Tag="Network"/>
                                <MenuItem Header="Windows" Click="SetType_Click" Tag="Windows"/>
                                <MenuItem Header="Windows Server" Click="SetType_Click" Tag="Windows Server"/>
                                <MenuItem Header="Linux/SSH" Click="SetType_Click" Tag="Linux/SSH"/>
                                <MenuItem Header="Server" Click="SetType_Click" Tag="Server"/>
                                <MenuItem Header="Printer" Click="SetType_Click" Tag="Printer"/>
                                <MenuItem Header="Smart TV" Click="SetType_Click" Tag="Smart TV"/>
                                <MenuItem Header="Apple TV" Click="SetType_Click" Tag="Apple TV"/>
                                <MenuItem Header="Media Streamer" Click="SetType_Click" Tag="Media Streamer"/>
                                <MenuItem Header="Apple Device" Click="SetType_Click" Tag="Apple Device"/>
                                <MenuItem Header="Mobile" Click="SetType_Click" Tag="Mobile"/>
                                <MenuItem Header="IoT" Click="SetType_Click" Tag="IoT"/>
                                <MenuItem Header="NAS" Click="SetType_Click" Tag="NAS"/>
                                <MenuItem Header="Camera" Click="SetType_Click" Tag="Camera"/>
                                <MenuItem Header="Hypervisor" Click="SetType_Click" Tag="Hypervisor"/>
                                <MenuItem Header="Home Assistant" Click="SetType_Click" Tag="Home Assistant"/>
                                <MenuItem Header="DNS Server" Click="SetType_Click" Tag="DNS Server"/>
                                <MenuItem Header="Web Device" Click="SetType_Click" Tag="Web Device"/>
                                <MenuItem Header="Other" Click="SetType_Click" Tag="Other"/>
                            </MenuItem>
                            <MenuItem Header="Clear Override" Click="ClearOverride_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource TableHeaderBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="IP Address" Binding="{Binding IpAddress}" Width="120" SortMemberPath="IpSortKey"/>
                        <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="170"/>
                        <DataGridTextColumn Header="MAC Address" Binding="{Binding MacAddress}" Width="145"/>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="*"/>
                        <DataGridTemplateColumn Header="Type" Width="120" SortMemberPath="DeviceType">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DeviceType}" FontWeight="Medium">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Router">
                                                        <Setter Property="Foreground" Value="#F0A030"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Windows">
                                                        <Setter Property="Foreground" Value="#60A0F0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Windows Server">
                                                        <Setter Property="Foreground" Value="#60A0F0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Printer">
                                                        <Setter Property="Foreground" Value="#D080A0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Switch/AP">
                                                        <Setter Property="Foreground" Value="#C0C0C0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Hypervisor">
                                                        <Setter Property="Foreground" Value="#E06060"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="NAS">
                                                        <Setter Property="Foreground" Value="#40C080"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="IoT">
                                                        <Setter Property="Foreground" Value="#B060D0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Server">
                                                        <Setter Property="Foreground" Value="#E08050"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Linux/SSH">
                                                        <Setter Property="Foreground" Value="#D0C050"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="DNS Server">
                                                        <Setter Property="Foreground" Value="#50B0D0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Home Assistant">
                                                        <Setter Property="Foreground" Value="#50D0A0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Mobile">
                                                        <Setter Property="Foreground" Value="#A0A0F0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Camera">
                                                        <Setter Property="Foreground" Value="#F0C060"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Apple Device">
                                                        <Setter Property="Foreground" Value="#C0C0C0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Smart TV">
                                                        <Setter Property="Foreground" Value="#E0A0E0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Apple TV">
                                                        <Setter Property="Foreground" Value="#C0C0C0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DeviceType}" Value="Media Streamer">
                                                        <Setter Property="Foreground" Value="#70C0E0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Open Ports" Binding="{Binding OpenPortsDisplay}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock x:Name="StatusText" Text="Ready"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <ProgressBar x:Name="ScanProgress"
                                 Width="200" Height="4" VerticalAlignment="Center"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 Background="{StaticResource CardBorderBrush}"
                                 Visibility="Collapsed" Margin="0,0,12,0"/>
                    <TextBlock x:Name="VersionLabel" Text="v1.2.0"
                               Foreground="#444444" FontFamily="Consolas"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock FontSize="10" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Hyperlink NavigateUri="https://github.com/SteveTheKiller/KillerScan"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#444444" TextDecorations="None">
                            <Run Text="Source"/>
                        </Hyperlink>
                        <Run Text=" &#x00B7; " Foreground="#444444"/>
                        <Hyperlink NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#444444" TextDecorations="None"
                                   ToolTip="KillerScan is free software licensed under GPLv3. It comes with ABSOLUTELY NO WARRANTY. You are free to redistribute it under the terms of the GNU General Public License version 3.">
                            <Run Text="GPLv3"/>
                        </Hyperlink>
                        <Run Text=" &#x00B7; NO WARRANTY" Foreground="#444444"/>
                    </TextBlock>
                    <TextBlock FontSize="10" VerticalAlignment="Center">
                        <Run Text="&#x00A9; 2026 " Foreground="#444444"/>
                        <Hyperlink NavigateUri="https://thekiller.net"
                                   RequestNavigate="Hyperlink_RequestNavigate"
                                   Foreground="#444444" TextDecorations="None">
                            <Run Text="Steve the Killer"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
